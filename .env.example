# FocusMath server configuration

# Set to 1/true/auto to use MySQL when available. Set to 0 to force JSON fallback.
MYSQL_ENABLED=auto
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=focusmath

# Optional: migrate JSON question bank to SQL when the server starts.
MYSQL_AUTO_MIGRATE=0

# Magic-link email. If unset, the login link is printed to the server console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Privacy pepper for email HMAC. Change this before deployment.
AUTH_PEPPER=change-this-before-deploying
